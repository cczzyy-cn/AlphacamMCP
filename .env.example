# AlphaCAM MCP Bridge 配置

# AlphaCAM COM ProgID（默认 aroutaps.Application）
# ALPHACAM_PROG_ID=aroutaps.Application

# AlphaCAM 安装目录（自动检测，通常无需设置）
# ALPHACAM_DIR=C:\Program Files (x86)\Vero Software\Alphacam 2016 R1

# AlphaCAM 窗口是否可见（1=可见 0=隐藏）
# ALPHACAM_VISIBLE=1

# SSE 模式端口（留空=使用 STDIO）
# ALPHACAM_PORT=8080

# SSE 模式 Bearer Token（留空=无认证）
# ALPHACAM_SSE_TOKEN=
